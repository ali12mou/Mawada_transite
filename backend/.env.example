BACKEND_PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/transit-transport
MONGODB_DB_NAME=transit-transport

# Supabase (API /api/transit, facture chambre, etc.)
# Soit ici, soit dans le .env à la racine du repo (chargé aussi au démarrage).
# URL : SUPABASE_URL ou VITE_SUPABASE_URL
# Clé : de préférence SUPABASE_SERVICE_ROLE_KEY (dashboard → Settings → API → service_role).
# Sinon clé anon (VITE_SUPABASE_ANON_KEY) si vos politiques RLS l’autorisent.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
