{
  "name": "systeme-transit-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "start npm run dev:backend && sleep 2 && npm run dev:frontend",
    "build": "npm run build --workspace=frontend"
  }
}